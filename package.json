{
  "name": "vite-project",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "@jridgewell/gen-mapping": "0.3.7"
    }
  },
  "scripts": {
    "trace:tchul-logo": "node scripts/trace-tchul-logo.mjs",
    "svg:fill-only": "node scripts/svg-to-fill-only.mjs",
    "logo:remove-bg": "node scripts/remove-white-background.mjs",
    "logo:crop-icon": "node scripts/crop-tchul-icon.mjs",
    "logo:remove-padding": "node scripts/crop-icon-padding.mjs",
    "dev": "vite",
    "dev:remote": "env-cmd -f .env.remote vite",
    "build": "vite build && node scripts/ensure-spa-mode.js",
    "verify:student-routes": "node scripts/verify-student-routes.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:e2e": "npx playwright test",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:ui": "npx playwright test --ui"
  },
  "dependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.60.0",
    "@sentry/react": "^10.43.0",
    "@swc/core-linux-x64-gnu": "^1.15.21",
    "@tanstack/react-query": "^5.90.12",
    "@tiptap/extension-color": "^2.12.0",
    "@tiptap/extension-image": "^2.12.0",
    "@tiptap/extension-link": "^2.12.0",
    "@tiptap/extension-placeholder": "^2.12.0",
    "@tiptap/extension-text-align": "^2.12.0",
    "@tiptap/extension-text-style": "^2.12.0",
    "@tiptap/extension-underline": "^2.12.0",
    "@tiptap/react": "^2.12.0",
    "@tiptap/starter-kit": "^2.12.0",
    "@types/dompurify": "^3.2.0",
    "antd": "^6.2.2",
    "axios": "^1.13.2",
    "dayjs": "^1.11.19",
    "dompurify": "^3.3.2",
    "hls.js": "^1.6.15",
    "lightningcss-linux-x64-gnu": "^1.32.0",
    "lucide-react": "^0.563.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.5.0",
    "react-router-dom": "^6.30.2",
    "recharts": "^3.7.0",
    "xlsx": "^0.18.5",
    "xlsx-js-style": "^1.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@jridgewell/gen-mapping": "0.3.7",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "4.1.18",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.0",
    "autoprefixer": "10",
    "dotenv": "^17.3.1",
    "env-cmd": "^11.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.14.0",
    "imagetracerjs": "^1.2.6",
    "pngjs": "^7.0.0",
    "postcss": "8",
    "sharp": "^0.34.5",
    "tailwindcss": "4.1.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.22.0",
    "vite": "^6.1.0"
  }
}
