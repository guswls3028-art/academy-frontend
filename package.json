{
  "name": "vite-project",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "@jridgewell/gen-mapping": "0.3.7",
      "form-data": "4.0.6",
      "linkify-it": "5.0.1",
      "markdown-it": "14.3.0",
      "uuid": "11.1.1"
    }
  },
  "scripts": {
    "dev": "vite",
    "dev:remote": "env-cmd -f .env.remote vite",
    "build": "vite build && node scripts/check-bundle-budgets.mjs && node scripts/ensure-spa-mode.js",
    "guard:legacy-api": "node scripts/guard-legacy-api-routes.mjs && node scripts/guard-staff-mobile-contract.mjs && node scripts/guard-messaging-policy.mjs && pnpm guard:e2e-safety",
    "guard:e2e-safety": "node scripts/guard-e2e-safety.mjs && node scripts/guard-strict-e2e-imports.mjs",
    "verify:student-routes": "node scripts/verify-student-routes.mjs",
    "verify:teacher-routes": "node scripts/verify-teacher-routes.mjs",
    "verify:landing-routes": "node scripts/verify-landing-routes.mjs",
    "verify:admin-routes": "node scripts/verify-admin-routes.mjs",
    "verify:tenant-availability": "node scripts/verify-tenant-availability.mjs",
    "verify:routes": "pnpm verify:student-routes && pnpm verify:teacher-routes && pnpm verify:landing-routes && pnpm verify:admin-routes",
    "refactor:inventory": "node scripts/refactor-boundary-snapshot.mjs",
    "refactor:budget": "node scripts/refactor-boundary-snapshot.mjs --budget scripts/refactor-budget-baseline.json",
    "typecheck": "pnpm typecheck:app && pnpm typecheck:functions",
    "typecheck:app": "tsc --noEmit -p tsconfig.app.json",
    "typecheck:functions": "tsc --noEmit -p tsconfig.functions.json",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:canary": "playwright test e2e/smoke/production-canary.spec.ts --project=chromium --reporter=list",
    "test:e2e:gate": "playwright test e2e/admin/01-login-dashboard.spec.ts e2e/student/01-login-dashboard.spec.ts e2e/smoke/smoke.spec.ts e2e/auth/account-recovery-modal.spec.ts e2e/flows/notice-roundtrip.spec.ts e2e/flows/qna-roundtrip.spec.ts e2e/flows/clinic-roundtrip.spec.ts e2e/flows/password-reset-roundtrip.spec.ts e2e/shared/03-tenant-isolation.spec.ts",
    "test:e2e:landing-routes": "playwright test e2e/refactor/landing-router.spec.ts",
    "test:e2e:visual-audit": "playwright test e2e/visual/design-system-route-audit.spec.ts --project=chromium --reporter=list",
    "test:e2e:local": "playwright test e2e/_local/",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.1",
    "@rollup/rollup-linux-x64-gnu": "^4.60.0",
    "@rollup/rollup-win32-x64-msvc": "^4.60.0",
    "@sentry/react": "^10.43.0",
    "@swc/core-linux-x64-gnu": "^1.15.21",
    "@swc/core-win32-x64-msvc": "^1.15.21",
    "@tanstack/react-query": "^5.90.12",
    "@tiptap/extension-color": "^2.12.0",
    "@tiptap/extension-image": "^2.12.0",
    "@tiptap/extension-link": "^2.12.0",
    "@tiptap/extension-placeholder": "^2.12.0",
    "@tiptap/extension-text-align": "^2.12.0",
    "@tiptap/extension-text-style": "^2.12.0",
    "@tiptap/extension-underline": "^2.12.0",
    "@tiptap/react": "^2.12.0",
    "@tiptap/starter-kit": "^2.12.0",
    "antd": "^6.2.2",
    "axios": "^1.16.0",
    "dayjs": "^1.11.19",
    "dompurify": "^3.4.11",
    "exceljs": "^4.4.0",
    "heic2any": "^0.0.4",
    "hls.js": "^1.6.15",
    "lightningcss-linux-x64-gnu": "^1.32.0",
    "lightningcss-win32-x64-msvc": "^1.32.0",
    "lucide-react": "^0.563.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.7.284",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.5.0",
    "react-router-dom": "^6.30.4",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260719.1",
    "@eslint/js": "^9.19.0",
    "@jridgewell/gen-mapping": "0.3.7",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "4.1.18",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.0",
    "autoprefixer": "10",
    "dotenv": "^17.3.1",
    "env-cmd": "^11.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.14.0",
    "postcss": "8",
    "tailwindcss": "4.1.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.22.0",
    "vite": "^6.1.0"
  }
}
