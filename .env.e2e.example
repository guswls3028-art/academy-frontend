# 운영 계정 안내/실발송 E2E 통제 수신번호. 다른 번호는 safety guard가 차단한다.
E2E_REAL_ALIMTALK_CONTROLLED_PHONE=01031217466
# 실제 provider 발송 spec은 기본 skip. 통제번호 전용 수동 canary에서만 1.
E2E_ALLOW_REAL_ALIMTALK=0

E2E_STRICT=report
